# Optional. Enables high-fidelity conversion via the self-hosted LibreOffice
# service in convert-service/ (run with `docker compose up --build -d`):
# Word/PowerPoint/Excel -> PDF, and PDF -> Word/PowerPoint. Without this,
# those conversions fall back to fully client-side extraction/generation in
# the browser (PDF -> Excel always uses the client-side path - LibreOffice
# has no PDF import filter for Calc).
VITE_CONVERT_API_URL=http://localhost:3000/convert
