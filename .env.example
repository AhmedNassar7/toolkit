# Required for PDF to Word / PowerPoint / Excel (calls a Supabase Edge Function).
# Get these from your Supabase project: Settings > API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional. Only needed for high-fidelity Word-to-PDF via the LibreOffice
# service in convert-service/ (run with `docker compose up --build -d`).
# Without this, Word-to-PDF still works using basic local text extraction.
VITE_CONVERT_API_URL=http://localhost:3000/convert
