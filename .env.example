# Required for PDF to Word / PowerPoint / Excel (calls a Supabase Edge Function).
# Get these from your Supabase project: Settings > API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional. Enables high-fidelity conversion via the LibreOffice service in
# convert-service/ (run with `docker compose up --build -d`): Word/PowerPoint/
# Excel -> PDF, and PDF -> Word/PowerPoint. Without this, those conversions
# fall back to basic local text extraction (PDF -> Excel always uses the
# fallback - LibreOffice has no PDF import filter for Calc).
VITE_CONVERT_API_URL=http://localhost:3000/convert
